# === Supabase ===
# Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=<your supabase project url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your supabase anon key>
# Server-only, never expose to the client. Used for admin user creation, grading, signed URLs.
SUPABASE_SERVICE_ROLE_KEY=<your supabase service role key>

# === Email (Resend) ===
# https://resend.com — verify a sending domain before going live
RESEND_API_KEY=<your resend api key>
EMAIL_FROM="Proctored Exams <exams@yourdomain.com>"

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Random long string used to sign short-lived tokens (e.g. password-reset helpers)
APP_SECRET=<random-32-byte-hex-string>

# === Super Admin bootstrap (used once by scripts/seed-super-admin.ts) ===
SUPER_ADMIN_EMAIL=<super-admin@yourdomain.com>
SUPER_ADMIN_PASSWORD=<choose-a-strong-password>
SUPER_ADMIN_NAME="Platform Owner"
